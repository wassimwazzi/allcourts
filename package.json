    "format": "turbo run format"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.0.0",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
