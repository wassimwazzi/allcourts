{
  "name": "allcourts",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "dev:web": "pnpm --filter @allcourts/web dev",
    "dev:mobile": "pnpm --filter @allcourts/mobile start",
    "dev:functions": "pnpm --filter @allcourts/functions dev",
